# Copied into Railway Variables (or local .env for development).
# PORT and HOST are set automatically on Railway; do not hardcode in code.

# Set by Railway — public HTTP port for the service
# PORT=8080

# Bind address (default 0.0.0.0 — required for Railway)
# HOST=0.0.0.0

# Optional: full public HTTPS URL for logs only (e.g. https://your-service.up.railway.app)
# PUBLIC_BASE_URL=https://your-service.up.railway.app

# Shared secret: set the same value in Supabase Edge Function secret WHATSAPP_OTP_SERVICE_TOKEN
# WHATSAPP_OTP_SERVICE_TOKEN=

# Persist Baileys session outside the container (mount a Railway volume, then point here)
# Example: mount volume at /data and set:
# WHATSAPP_AUTH_DIR=/data
